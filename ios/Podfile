# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

# react-native-permissions ships with zero permission handlers compiled in
# by default; without this, RNPermissions.check()/request() throw "No
# permission handler detected" at runtime for every permission. Only the
# permissions this app actually declares usage strings for.
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native-permissions/scripts/setup.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

setup_permissions([
  'Camera',
  'Microphone',
  'PhotoLibraryAddOnly',
])

# AppIntents/AppShortcutsProvider (OpenCameraIntent) requires iOS 16.0+,
# above RN's own 15.1 floor.
platform :ios, '16.0'
prepare_react_native_project!

# Firebase Analytics is usage-stats only here (no ads), so skip the ad-id
# variant -- it would otherwise require an App Tracking Transparency prompt.
$RNFirebaseAnalyticsWithoutAdIdSupport = true

# Required for RNFB's Swift pods (e.g. FirebaseCoreInternal) to build as
# static libraries -- see "cannot yet be integrated as static libraries" error.
use_modular_headers!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'Peguei' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # use_modular_headers! (above) makes plain-C pods like nanopb (a Firebase
    # transitive dep) modular too, which then fails to compile with
    # "non-modular-include-in-framework-module" treated as a hard error.
    # Allowing non-modular includes is the standard fix for this combination.
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
      end
    end
  end
end
