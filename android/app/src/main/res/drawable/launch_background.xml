<?xml version="1.0" encoding="utf-8"?>
<!-- App launch background: brand backgroundDark behind the real Peguei launcher icon,
     replacing the unbranded default AppTheme window background. See DECISIONS.md. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/backgroundDark"/>
    <item android:gravity="center" android:width="132dp" android:height="132dp">
        <bitmap android:src="@mipmap/ic_launcher" android:gravity="center"/>
    </item>
</layer-list>
