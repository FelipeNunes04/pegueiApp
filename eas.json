{
  "cli": {
    "version": ">= 16.20.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development"
    },
    "preview": {
      "distribution": "internal",
      "environment": "preview"
    },
    "preview-android": {
      "extends": "preview",
      "credentialsSource": "local"
    },
    "production": {
      "autoIncrement": true,
      "environment": "production"
    },
    "production-android": {
      "extends": "production",
      "credentialsSource": "local",
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6790596334"
      }
    }
  }
}
