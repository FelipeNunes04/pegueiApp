{
  "name": "Peguei",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "eas-build-pre-install": "bash scripts/eas-build-pre-install.sh",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "e2e:build:ios": "detox build -c ios.sim.debug",
    "e2e:test:ios": "detox test -c ios.sim.debug",
    "screenshots:ios:69": "detox test -c ios.sim.screenshots.69 e2e/screenshots.test.ts",
    "screenshots:ios:65": "detox test -c ios.sim.screenshots.65 e2e/screenshots.test.ts",
    "screenshots:ios:ipad13": "detox test -c ios.sim.screenshots.ipad13 e2e/screenshots.test.ts",
    "screenshots:ios": "detox build -c ios.sim.screenshots.69 && yarn screenshots:ios:69 && yarn screenshots:ios:65 && yarn screenshots:ios:ipad13",
    "credentials:ios": "eas credentials --platform ios",
    "build:ios:preview": "eas build --platform ios --profile preview",
    "build:ios": "eas build --platform ios --profile production",
    "submit:ios": "eas submit --platform ios --latest"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.1.1",
    "@react-native-clipboard/clipboard": "^1.16.3",
    "@react-native-community/slider": "^5.2.0",
    "@react-native-firebase/analytics": "^25.1.0",
    "@react-native-firebase/app": "^25.1.0",
    "@react-navigation/native": "^7.3.8",
    "@react-navigation/native-stack": "^7.17.10",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-create-thumbnail": "^2.2.0",
    "react-native-fs": "^2.20.0",
    "react-native-permissions": "^5.6.0",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.26.0",
    "react-native-share": "^12.3.1",
    "react-native-svg": "^15.15.5",
    "react-native-video": "^6.19.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@config-plugins/detox": "^11.0.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/eslint-config": "0.86.0",
    "@react-native/jest-preset": "0.86.0",
    "@react-native/metro-config": "0.86.0",
    "@react-native/typescript-config": "0.86.0",
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "detox": "^20.51.4",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "jest-circus": "^30.4.2",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "test-renderer": "^1.0.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  },
  "packageManager": "yarn@3.6.4"
}
